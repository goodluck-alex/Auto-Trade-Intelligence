# LIDEX AUTO TRADE - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values

# --- API Configuration ---
# Source for real-time market prices (Binance API)
VITE_BINANCE_API=https://api.binance.com

# --- Feature Flags ---
# Set to true to enable local simulation/demo mode data persistence
VITE_ENABLE_MOCK=true
# Application Environment (development, production)
VITE_APP_ENV=development

# --- Branding & Customization ---
# Title of the platform
VITE_APP_TITLE="Lidex Auto Trade"
# Primary color theme (emerald, purple, etc.)
VITE_PRIMARY_COLOR=emerald

# --- Security & Auth (Production Recommendations) ---
# In a real production environment, these would be your backend endpoints
# VITE_API_BASE_URL=https://api.lidex.io/v1
# VITE_WS_URL=wss://ws.lidex.io

# --- Storage ---
# Prefix for localStorage to avoid conflicts
VITE_STORAGE_PREFIX=lidex_v1_
