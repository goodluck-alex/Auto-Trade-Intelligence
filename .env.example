# LIDEX AUTO TRADE - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values

# --- API Configuration ---
# Source for real-time market prices (Binance API)
VITE_BINANCE_API=https://api.binance.com

# --- Feature Flags ---
# Set to true to enable local simulation/demo mode data persistence
VITE_ENABLE_MOCK=true
# Application Environment (development, production)
VITE_APP_ENV=development

# --- Branding & Customization ---
# Title of the platform
VITE_APP_TITLE="Lidex Auto Trade"
# Primary color theme (emerald, purple, etc.)
VITE_PRIMARY_COLOR=emerald

# --- Security & Auth (Production Recommendations) ---
# Backend API — leave empty for local dev (Vite proxies to localhost:4000)
# For production: https://auto-trade-backend-lpsb.onrender.com
VITE_API_BASE_URL=
# OAuth token exchange — use /oauth/exchange locally, full URL in production
VITE_OAUTH_TOKEN_ENDPOINT=/oauth/exchange
# OAuth redirect — must match Google/GitHub app settings exactly
# Local: http://localhost:5173/oauth-callback.html
# Production: https://lidex-auto.vercel.app/oauth-callback.html
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth-callback.html
# Set your OAuth client IDs below
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GITHUB_CLIENT_ID=your-github-client-id

# --- Storage ---
# Prefix for localStorage to avoid conflicts
VITE_STORAGE_PREFIX=lidex_v1_
